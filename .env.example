# LitExtract — environment variables.
#
# DEPLOYMENT MODES
#
# 1. Public BYOK (Hugging Face Spaces / shared demo):
#       OPENAI_API_KEY=
#       ALLOWED_ORIGINS=https://your-username-litextract.hf.space
#    Leave OPENAI_API_KEY EMPTY. The UI will require each user to paste
#    their own key (stored only in their browser).
#
# 2. Private self-host (your team only):
#       OPENAI_API_KEY=sk-...
#       ALLOWED_ORIGINS=http://localhost:7860
#    Set your key. Users won't be prompted; the server-side key is used.
#
# Copy this file to `.env` and fill values. NEVER commit `.env` to git.
# (.gitignore already excludes it.)

# ---- LLM provider routing ----
# one of: openai | anthropic | azure-openai
LLM_PROVIDER=openai

# ---- OpenAI (primary path) ----
# Leave EMPTY for public BYOK deploys.
OPENAI_API_KEY=
OPENAI_COMPLETION_MODEL=gpt-4o-mini

# ---- Anthropic (optional, comparison runs only) ----
ANTHROPIC_API_KEY=
ANTHROPIC_COMPLETION_MODEL=claude-sonnet-4-5

# ---- Azure OpenAI (optional) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_COMPLETION_DEPLOYMENT=gpt-4o-mini

# ---- Embeddings (only used by the legacy batch flow) ----
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
USE_EMBEDDINGS=true

# ---- Azure Document Intelligence (legacy batch flow only — UI uses local PDF parser) ----
DOCUMENTINTELLIGENCE_ENDPOINT=
DOCUMENTINTELLIGENCE_API_KEY=

# ---- Azure Blob Storage (legacy batch flow only) ----
AZURE_STORAGE_CONNECTION_STRING=
INPUT_CONTAINER=biomarker-ragcontainer
OUTPUT_CONTAINER=di-output

# ---- Pipeline behaviour ----
TRAINING_MODE=true

# ---- Web server / deployment ----
# Port the FastAPI server listens on. Hugging Face Spaces uses 7860.
# Render / Fly inject their own PORT; you can leave this default.
PORT=7860

# Comma-separated list of allowed CORS origins. Set this in production!
# Empty -> dev defaults (http://localhost:5173, http://127.0.0.1:5173).
ALLOWED_ORIGINS=
